# Public — safe to commit. Mirrors the real project/dataset.
NEXT_PUBLIC_SANITY_PROJECT_ID=vwtvhoy4
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-01

# Read token — create a VIEWER token: sanity.io/manage -> project vwtvhoy4 -> API -> Tokens.
# Used for live updates (Live Content API) and draft-mode/visual editing reads.
SANITY_API_READ_TOKEN=

# Write token — only needed to run `pnpm seed`. Create an EDITOR token.
# Never commit this. Leave blank in normal operation.
SANITY_API_WRITE_TOKEN=
